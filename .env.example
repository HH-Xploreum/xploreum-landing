# PostHog — set these in Vercel project env vars and locally in .env.local.
# Grab the project key from https://us.posthog.com → Project settings → Project API key.
NEXT_PUBLIC_POSTHOG_KEY=phc_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Waitlist webhook — POST destination for the footer "Notify me" form.
# /api/waitlist forwards { email, source, submittedAt } as JSON.
# Plug in any service that accepts JSON webhooks: Loops, Resend, Zapier,
# Make, n8n, a Supabase Edge Function, etc. If unset, /api/waitlist still
# returns 200 OK and logs the submission to the server console (dev mode).
WAITLIST_WEBHOOK_URL=
